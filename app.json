{
  "expo": {
    "name": "Nane",
    "slug": "nane-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/nane-logo.png",
    "scheme": "nane",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.mdoetech.nane-mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow Nane to use Face ID so you can unlock your saved workspace securely."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.mdoetech.nanemobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/nane-splash-logo.png",
          "imageWidth": 156,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0F172A",
            "image": "./assets/images/nane-splash-logo.png"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Nane to use Face ID so you can unlock your saved workspace securely."
        }
      ],
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#2563EB",
          "defaultChannel": "nane-default"
        }
      ],
      "./plugins/with-nane-report-downloads",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "naneApiBaseUrl": "https://app.nane.co.tz/api/v1",
      "nanePushDeviceRegistrationPath": "/mobile/push/devices",
      "nanePushDeviceUnregistrationPath": "/mobile/push/devices/unregister"
    }
  }
}
